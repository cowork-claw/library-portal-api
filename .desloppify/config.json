{
  "target_strict_score": 95,
  "review_max_age_days": 30,
  "review_batch_max_files": 80,
  "holistic_max_age_days": 30,
  "generate_scorecard": true,
  "badge_path": "scorecard.png",
  "exclude": [],
  "ignore": [
    "security::.*::B101::tests/.*",
    "smells::.*::import_path_mutation",
    "smells::.*::sys_exit_in_library",
    "smells::.*::swallowed_error",
    "smells::.*::broad_except",
    "test_coverage::.*::transitive_only",
    "structural::.*",
    "security::app_v2/middleware/auth.py::security::hardcoded_secret_name::app_v2/middleware/auth.py::.*",
    "security::.*::B101::.*"
  ],
  "ignore_metadata": {},
  "zone_overrides": {
    "scripts/*.py": "script",
    "scraper/library_scraper/spiders/*.py": "script",
    "scraper/library_scraper/items.py": "script",
    "scraper/library_scraper/middlewares.py": "script",
    "scraper/scrape_log.py": "script"
  },
  "review_dimensions": [],
  "large_files_threshold": 0,
  "props_threshold": 0,
  "finding_noise_budget": 10,
  "finding_noise_global_budget": 0,
  "languages": {}
}
