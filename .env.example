# Library Portal API V2 - Example Environment Configuration
# Copy this file to .env and fill in the values

# =============================================================================
# ENVIRONMENT
# =============================================================================
# 'development' or 'production'
LIBRARY_PORTAL_ENVIRONMENT=development
LIBRARY_PORTAL_LOG_LEVEL=INFO

# =============================================================================
# SECURITY
# =============================================================================

# API Authentication - REQUIRED for production
# Generate a strong key: python -c "import secrets; print(secrets.token_urlsafe(32))"
# If not set in development, the API will be accessible without authentication (with warnings)
LIBRARY_PORTAL_API_KEY=your-secure-api-key-here

# CORS - Comma separated list of allowed origins
# In production, set to your frontend domain(s) e.g., https://myapp.com
LIBRARY_PORTAL_CORS_ORIGINS=http://localhost:3000,http://localhost:4321

# =============================================================================
# SCRAPER CONFIGURATION
# =============================================================================

# Optional: Override default thresholds
# LIBRARY_PORTAL_TARGET_YEAR_THRESHOLD=2024
